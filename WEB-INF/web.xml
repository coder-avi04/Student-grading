<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd"
         version="6.0">

    <display-name>Student Grading System - Enterprise Edition</display-name>
    <description>Enterprise-grade student grading system with security, logging, and audit compliance</description>

    <!-- ========== Global Configuration ========== -->
    <session-config>
        <cookie>
            <secure>true</secure>
            <http-only>true</http-only>
        </cookie>
        <tracking-mode>COOKIE</tracking-mode>
    </session-config>

    <!-- ========== Authentication and Security Filter ========== -->
    <filter>
        <filter-name>AuthFilter</filter-name>
        <filter-class>com.sgs.filter.AuthFilter</filter-class>
        <description>Enterprise authentication and session validation filter</description>
    </filter>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/*</url-pattern>
        <dispatcher>REQUEST</dispatcher>
        <dispatcher>FORWARD</dispatcher>
    </filter-mapping>

    <!-- ========== Authentication Handler Servlet ========== -->
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.sgs.servlet.LoginServlet</servlet-class>
        <description>Enterprise login and session management</description>
        <load-on-startup>1</load-on-startup>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <!-- ========== Student and Analytics Manager Servlet ========== -->
    <servlet>
        <servlet-name>StudentServlet</servlet-name>
        <servlet-class>com.sgs.servlet.StudentServlet</servlet-class>
        <description>Student management and analytics operations</description>
        <load-on-startup>2</load-on-startup>
    </servlet>
    <servlet-mapping>
        <servlet-name>StudentServlet</servlet-name>
        <url-pattern>/student</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>StudentServlet</servlet-name>
        <url-pattern>/students</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>StudentServlet</servlet-name>
        <url-pattern>/dashboard</url-pattern>
    </servlet-mapping>

    <!-- ========== Welcome File Definition ========== -->
    <welcome-file-list>
        <welcome-file>index.html</welcome-file>
        <welcome-file>login.html</welcome-file>
    </welcome-file-list>

    <!-- ========== Error Handlers ========== -->
    <error-page>
        <error-code>400</error-code>
        <location>/error400.jsp</location>
    </error-page>
    <error-page>
        <error-code>401</error-code>
        <location>/error401.jsp</location>
    </error-page>
    <error-page>
        <error-code>403</error-code>
        <location>/error403.jsp</location>
    </error-page>
    <error-page>
        <error-code>404</error-code>
        <location>/error404.jsp</location>
    </error-page>
    <error-page>
        <error-code>500</error-code>
        <location>/error500.jsp</location>
    </error-page>
    <error-page>
        <exception-type>java.lang.Exception</exception-type>
        <location>/error500.jsp</location>
    </error-page>

    <!-- ========== Application Context Settings ========== -->
    <listener>
        <listener-class>com.sgs.listener.ApplicationInitializer</listener-class>
    </listener>

    <!-- ========== Servlet Configuration ========== -->
    <init-param>
        <param-name>application-name</param-name>
        <param-value>Student Grading System</param-value>
    </init-param>
    <init-param>
        <param-name>version</param-name>
        <param-value>2.0</param-value>
    </init-param>

</web-app>
